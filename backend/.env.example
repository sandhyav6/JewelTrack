# JewelTrack Backend — Environment Configuration
# Copy this file to .env and fill in your Oracle credentials.

# Oracle Application User (NOT SYS / SYSDBA)
ORACLE_USER=JEWELTRACK_APP
ORACLE_PASSWORD=JewelTrack@2024

# Oracle connect string — adjust for your Oracle installation:
#   Oracle XE on localhost:          localhost:1521/XE
#   Oracle XE with PDB (18c+):       localhost:1521/XEPDB1
#   Oracle with service name:        hostname:port/service_name
ORACLE_CONNECT_STRING=DESKTOP-SV698E9:1521/xepdb1

# Express server port
PORT=3000
